# Interpolation marker files used to drive foreach rules.
# Tup creates parent dirs for declared outputs, so no explicit mkdir is needed.
: |> touch .interps/bilinear .interps/bicubic |> .interps/bilinear .interps/bicubic

# Demo objects: tabulated compressor maps (dimensional)
: |> julia --project=.. ../scripts/create_demo_object.jl compressor_tabulated compressor/map/dim/bilinear/demo_tabulated_compressor_map.toml --interpolation bilinear |> compressor/map/dim/bilinear/demo_tabulated_compressor_map.toml
: |> julia --project=.. ../scripts/create_demo_object.jl compressor_tabulated compressor/map/dim/bicubic/demo_tabulated_compressor_map.toml --interpolation bicubic |> compressor/map/dim/bicubic/demo_tabulated_compressor_map.toml

# Demo objects: tabulated compressor maps (non-dimensional)
: |> julia --project=.. ../scripts/create_demo_object.jl compressor_nondimensional_tabulated compressor/map/nd/bilinear/demo_tabulated_nondimensional_compressor_map.toml --interpolation bilinear |> compressor/map/nd/bilinear/demo_tabulated_nondimensional_compressor_map.toml
: |> julia --project=.. ../scripts/create_demo_object.jl compressor_nondimensional_tabulated compressor/map/nd/bicubic/demo_tabulated_nondimensional_compressor_map.toml --interpolation bicubic |> compressor/map/nd/bicubic/demo_tabulated_nondimensional_compressor_map.toml

# Demo object: meanline model
: |> julia --project=.. ../scripts/create_demo_object.jl compressor_meanline_model compressor/meanline/demo_compressor_meanline_model.toml |> compressor/meanline/demo_compressor_meanline_model.toml

# Convert meanline model -> non-dimensional map (both interpolations)
: foreach .interps/bilinear .interps/bicubic | compressor/meanline/demo_compressor_meanline_model.toml |> julia --project=.. ../scripts/generate_compressor_map_from_meanline_model.jl compressor/meanline/demo_compressor_meanline_model.toml compressor/map/nd/%b/demo_compressor_map_from_meanline.toml --input-group compressor_meanline_model --output-group compressor_map --output-format nondimensional --interpolation %b |> compressor/map/nd/%b/demo_compressor_map_from_meanline.toml

# Performance map plots
: compressor/map/dim/bilinear/demo_tabulated_compressor_map.toml |> julia --project=.. ../scripts/plot_performance_map.jl compressor/map/dim/bilinear/demo_tabulated_compressor_map.toml --kind compressor --output compressor/map/dim/bilinear/demo_tabulated_compressor_map_performance_map.png |> compressor/map/dim/bilinear/demo_tabulated_compressor_map_performance_map.png
: compressor/map/dim/bicubic/demo_tabulated_compressor_map.toml |> julia --project=.. ../scripts/plot_performance_map.jl compressor/map/dim/bicubic/demo_tabulated_compressor_map.toml --kind compressor --output compressor/map/dim/bicubic/demo_tabulated_compressor_map_performance_map.png |> compressor/map/dim/bicubic/demo_tabulated_compressor_map_performance_map.png
